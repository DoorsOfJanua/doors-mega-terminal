{
  "name": "doors-mega-terminal",
  "version": "0.3.0",
  "description": "DMT — Doors Mega Terminal. A floating multi-window terminal manager for builders.",
  "main": "main.js",
  "author": "Janua",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite build --watch\" \"wait-on renderer/dist/index.html && electron .\"",
    "build:renderer": "vite build",
    "start": "npm run build:renderer && electron .",
    "test": "jest",
    "postinstall": "electron-builder install-app-deps && find node_modules/node-pty/prebuilds -name '*-helper' -exec chmod +x {} \\;",
    "dist": "npm run build:renderer && electron-builder --mac dmg"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.doorsofjanua.dmt",
    "productName": "Doors Mega Terminal",
    "icon": "assets/icon.icns",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.js",
      "pty-manager.js",
      "renderer/dist/**/*",
      "renderer/welcome.html"
    ],
    "extraResources": [
      { "from": "assets", "to": "assets" }
    ]
  }
}
